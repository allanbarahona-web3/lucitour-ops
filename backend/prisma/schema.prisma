generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  orgId         String
  email         String
  fullName      String
  passwordHash  String
  isActive      Boolean      @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  roles         UserRole[]
  sessions      AuthSession[]
  authEvents    AuthEvent[]
  passwordResetTokens PasswordResetToken[]

  @@unique([orgId, email])
  @@index([orgId, isActive])
  @@map("users")
}

model UserRole {
  userId        String
  orgId         String
  role          AppRole
  assignedAt    DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([orgId, role])
  @@map("user_roles")
}

model AuthSession {
  id               String      @id @default(cuid())
  orgId            String
  userId           String
  jti              String      @unique
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedByJti    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, userId])
  @@index([orgId, expiresAt])
  @@map("auth_sessions")
}

model AuthEvent {
  id               String        @id @default(cuid())
  orgId            String
  userId           String?
  email            String?
  eventType        AuthEventType
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime      @default(now())

  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, eventType, createdAt])
  @@index([orgId, email, createdAt])
  @@map("auth_events")
}

model PasswordResetToken {
  id               String        @id @default(cuid())
  orgId            String
  userId           String
  tokenHash        String        @unique
  expiresAt        DateTime
  usedAt           DateTime?
  requestedByIp    String?
  createdAt        DateTime      @default(now())

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, userId])
  @@index([orgId, expiresAt])
  @@map("password_reset_tokens")
}

model SignatureRequest {
  id                           String                 @id @default(cuid())
  orgId                        String
  contractId                   String
  recipientEmail               String
  recipientName                String?
  status                       SignatureRequestStatus @default(PENDING_OTP)
  publicToken                  String                 @unique @default(cuid())
  contractFileName             String?
  unsignedPdfObjectKey         String?
  unsignedPdfSha256            String?
  unsignedPdfSizeBytes         Int?
  otpCodeHash                  String?
  otpSentAt                    DateTime?
  otpAttemptCount              Int                    @default(0)
  otpLockedUntil               DateTime?
  otpValidatedAt               DateTime?
  signatureImageObjectKey      String?
  signatureImageSha256         String?
  signatureImageSizeBytes      Int?
  submittedAt                  DateTime?
  reviewedByUserId             String?
  approvedAt                   DateTime?
  rejectedAt                   DateTime?
  rejectionReason              String?
  lucitoursSignatureObjectKey  String?
  lucitoursSignatureSha256     String?
  lucitoursSignatureSizeBytes  Int?
  signedPdfObjectKey           String?
  signedPdfSha256              String?
  signedPdfSizeBytes           Int?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  events                       SignatureRequestEvent[]

  @@index([orgId, status])
  @@index([orgId, contractId])
  @@map("signature_requests")
}

model ContractDocument {
  id              String               @id @default(cuid())
  orgId           String
  contractId      String
  type            ContractDocumentType
  objectKey       String               @unique
  originalName    String?
  ownerName       String?
  concept         String?
  conceptOther    String?
  contentType     String
  sizeBytes       Int
  sha256          String
  uploadedByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([orgId, contractId])
  @@index([orgId, type])
  @@map("contract_documents")
}

model SignatureRequestEvent {
  id               String            @id @default(cuid())
  orgId            String
  signatureRequestId String
  type             SignatureEventType
  actorType        SignatureActorType
  actorId          String?
  metadata         Json?
  createdAt        DateTime          @default(now())

  signatureRequest SignatureRequest  @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)

  @@index([orgId, signatureRequestId])
  @@map("signature_request_events")
}

enum SignatureRequestStatus {
  PENDING_OTP
  PENDING_SIGNATURE
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SignatureEventType {
  REQUEST_CREATED
  OTP_GENERATED
  OTP_FAILED
  SIGNATURE_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
}

enum SignatureActorType {
  SYSTEM
  CLIENT
  CONTRACTOR
  ADMIN
}

enum ContractDocumentType {
  CEDULA_FRONT
  CEDULA_BACK
  PASSPORT
  MINOR_PERMIT
  INSURANCE
  PAYMENT_PROOF
  PROFILE_PHOTO_1
  PROFILE_PHOTO_2
}

enum AppRole {
  ADMIN
  AGENT
  SUPERVISOR
  ACCOUNTING
  CONTRACTS
  QUOTES
  BILLING
  PURCHASES
  VIEWER
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  TOKEN_REFRESHED
  LOGOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}
